<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>アップロード一覧</h1>
  <%= link_to "新規アップロード", new_image_group_path, class: "btn btn-primary" %>
</div>

<% if @image_groups.any? %>
  <p class="text-muted"><%== @pagy.info_tag %></p>

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="table-dark">
        <tr>
          <th><%= sort_link("ID", :id, @sort, @dir) %></th>
          <th><%= sort_link("日時", :created_at, @sort, @dir) %></th>
          <th>画像数</th>
          <th>ステータス</th>
          <th>メモ</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% @image_groups.each do |group| %>
          <tr>
            <td><%= link_to group.id, image_group_path(group) %></td>
            <td><%= group.created_at.strftime("%Y-%m-%d %H:%M:%S") %></td>
            <td><%= group.images_count %> 件</td>
            <td><%= group.status_summary %></td>
            <td><%= group.memo %></td>
            <td class="text-nowrap">
              <%= link_to image_group_path(group), class: "btn btn-sm btn-outline-primary", title: "詳細" do %>
                <i class="bi bi-eye"></i>
              <% end %>
              <% if group.completed_count > 0 %>
                <%= link_to download_image_group_path(group, format: "txt"), class: "btn btn-sm btn-outline-success", title: "ダウンロード" do %>
                  <i class="bi bi-download"></i>
                <% end %>
              <% else %>
                <span class="btn btn-sm btn-outline-secondary disabled" title="完了した画像がありません">
                  <i class="bi bi-download"></i>
                </span>
              <% end %>
              <%= link_to image_group_path(group), class: "btn btn-sm btn-outline-danger", title: "削除", data: { turbo_method: :delete, turbo_confirm: "グループ内の全ての画像も削除されます。本当に削除しますか？" } do %>
                <i class="bi bi-trash"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <nav aria-label="ページナビゲーション">
    <%== @pagy.series_nav %>
  </nav>
<% else %>
  <div class="alert alert-info">
    <%= link_to "新規アップロード", new_image_group_path %>で画像をアップロードしてください。
  </div>
<% end %>
