<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>アップロード #<%= @image_group.id %></h1>
  <%= link_to "一覧に戻る", image_groups_path, class: "btn btn-outline-secondary" %>
</div>

<div class="card mb-4">
  <div class="card-body">
    <% if @image_group.memo.present? %>
      <p class="card-text"><strong>メモ:</strong> <%= @image_group.memo %></p>
    <% end %>
    <p class="card-text">
      <span class="badge bg-secondary">画像数: <%= @image_group.images_count %> 件</span>
      <span class="badge bg-success">完了: <%= @image_group.completed_count %> 件</span>
      <span class="ms-2"><%= @image_group.status_summary %></span>
    </p>
    <% all_completed = @image_group.completed_count == @image_group.images_count && @image_group.images_count > 0 %>
    <% if all_completed %>
      <%= link_to "一括ダウンロード (ZIP)", download_image_group_path(@image_group, format: "txt"), class: "btn btn-success" %>
    <% else %>
      <button type="button" class="btn btn-success" disabled>一括ダウンロード (ZIP)</button>
      <small class="text-muted ms-2">全ての画像の処理が完了すると有効になります</small>
    <% end %>
  </div>
</div>

<h2 class="mb-3">画像一覧</h2>

<% if @images.any? %>
  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="table-dark">
        <tr>
          <th style="width: 120px;">サムネイル</th>
          <th>ファイル名</th>
          <th>ステータス</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% @images.each do |image| %>
          <tr class="<%= 'table-warning' if image.purged? %>">
            <td>
              <% if image.purged? %>
                <div class="d-flex align-items-center justify-content-center text-muted" style="width: 100px; height: 60px; background: #f8f9fa; border-radius: 4px;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M6.854 7.146a.5.5 0 1 0-.708.708L7.293 9l-1.147 1.146a.5.5 0 0 0 .708.708L8 9.707l1.146 1.147a.5.5 0 0 0 .708-.708L8.707 9l1.147-1.146a.5.5 0 0 0-.708-.708L8 8.293z"/>
                    <path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2M9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5z"/>
                  </svg>
                </div>
              <% elsif image.file.attached? && image.file.content_type.start_with?("image/") %>
                <%= image_tag image.file.variant(resize_to_limit: [100, 100]), class: "img-thumbnail" %>
              <% else %>
                <span class="text-muted">-</span>
              <% end %>
            </td>
            <td><%= image.name %></td>
            <td>
              <% if image.purged? %>
                <span class="badge bg-warning text-dark">削除済み</span>
              <% else %>
                <% case image.status %>
                <% when "pending" %>
                  <span class="badge bg-secondary">待機中</span>
                <% when "processing" %>
                  <span class="badge bg-primary">処理中</span>
                <% when "completed" %>
                  <span class="badge bg-success">完了</span>
                <% when "failed" %>
                  <span class="badge bg-danger">失敗</span>
                <% end %>
              <% end %>
            </td>
            <td>
              <%= link_to "詳細", image_path(image), class: "btn btn-sm btn-outline-primary" %>
              <% unless image.purged? %>
                <% if image.completed? && image.ocr_result.present? %>
                  <%= link_to "DL", download_image_path(image, format: "txt"), class: "btn btn-sm btn-outline-success", title: "ダウンロード" %>
                <% end %>
                <% if image.failed? || image.pending? %>
                  <%= link_to "再実行", retry_image_path(image), class: "btn btn-sm btn-outline-warning", data: { turbo_method: :post } %>
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="alert alert-info">
    画像がありません。
  </div>
<% end %>
