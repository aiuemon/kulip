<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>画像アップロード</h1>
  <%= link_to "一覧に戻る", image_groups_path, class: "btn btn-outline-secondary" %>
</div>

<div class="card">
  <div class="card-body">
    <%= form_with url: image_groups_path, method: :post, multipart: true do |f| %>
      <div class="mb-3">
        <label for="memo" class="form-label">メモ（省略可）</label>
        <%= text_field_tag :memo, nil, placeholder: "任意のメモを入力できます", class: "form-control" %>
      </div>

      <div class="mb-3">
        <label for="images" class="form-label">画像ファイル（複数選択可）</label>
        <%= file_field_tag "images[]", multiple: true, accept: "image/*", class: "form-control" %>
        <div class="form-text">JPEG, PNG, GIF 等の画像ファイルをアップロードできます。</div>
      </div>

      <div class="d-grid gap-2 d-md-flex justify-content-md-end">
        <%= f.submit "アップロード", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
