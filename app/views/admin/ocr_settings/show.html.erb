<h1>OCR 設定</h1>

<%= form_with model: @ocr_setting, url: admin_ocr_settings_path, method: :patch do |f| %>
  <% if @ocr_setting.errors.any? %>
    <div style="color: red;">
      <ul>
        <% @ocr_setting.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <h2>API 接続設定</h2>

  <div>
    <%= f.label :endpoint, "API エンドポイント" %><br>
    <%= f.text_field :endpoint, size: 60, placeholder: "例: http://localhost:11434/api/generate" %>
    <br>
    <small>OCR API の URL</small>
  </div>

  <div style="margin-top: 10px;">
    <%= f.label :api_key, "API キー" %><br>
    <%= f.text_field :api_key, size: 60, placeholder: "（任意）" %>
    <br>
    <small>API 認証が必要な場合に設定（Bearer トークンとして送信）</small>
  </div>

  <div style="margin-top: 10px;">
    <%= f.label :timeout, "タイムアウト（秒）" %><br>
    <%= f.number_field :timeout, min: 1, max: 3600, placeholder: OcrSetting::DEFAULT_TIMEOUT %>
    <br>
    <small>API リクエストのタイムアウト時間（デフォルト: <%= OcrSetting::DEFAULT_TIMEOUT %> 秒）</small>
  </div>

  <h2>モデル設定</h2>

  <div>
    <%= f.label :model, "モデル名" %><br>
    <%= f.text_field :model, size: 50, placeholder: "例: llava:latest" %>
    <br>
    <small>OCR に使用する VLM モデル名</small>
  </div>

  <h2>プロンプト設定</h2>

  <div>
    <%= f.label :prompt, "プロンプト" %><br>
    <%= f.text_area :prompt, rows: 8, cols: 80, placeholder: OcrSetting::DEFAULT_PROMPT %>
    <br>
    <small>空欄の場合はデフォルトのプロンプトが使用されます</small>
  </div>

  <h2>オプション設定</h2>

  <div>
    <%= f.label :options, "options (JSON)" %><br>
    <%= f.text_area :options, rows: 6, cols: 80,
        value: @ocr_setting.options.present? ? JSON.pretty_generate(@ocr_setting.options) : JSON.pretty_generate(OcrSetting::DEFAULT_OPTIONS) %>
    <br>
    <small>temperature, num_predict, num_ctx などの設定を JSON 形式で指定</small>
  </div>

  <div style="margin-top: 20px;">
    <%= f.submit "保存" %>
  </div>
<% end %>

<h2>現在の設定状態</h2>
<p>
  <strong>OCR 機能:</strong>
  <% if OcrApiClient.configured? %>
    <span style="color: green;">有効</span>
  <% else %>
    <span style="color: red;">無効</span>
    <br>
    <small>API エンドポイントとモデル名の設定が必要です</small>
  <% end %>
</p>

<p><%= link_to "管理者メニューに戻る", root_path %></p>
