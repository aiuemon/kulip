<h1 class="mb-4">OCR 設定</h1>

<%= form_with model: @ocr_setting, url: admin_ocr_settings_path, method: :patch do |f| %>
  <% if @ocr_setting.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @ocr_setting.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card mb-4">
    <div class="card-header">
      API 接続設定
    </div>
    <div class="card-body">
      <div class="mb-3">
        <%= f.label :endpoint, "API エンドポイント", class: "form-label" %>
        <%= f.text_field :endpoint, class: "form-control", placeholder: "例: http://localhost:11434/api/generate" %>
        <div class="form-text">OCR API の URL</div>
      </div>

      <div class="mb-3">
        <%= f.label :api_key, "API キー", class: "form-label" %>
        <%= f.text_field :api_key, class: "form-control", placeholder: "（任意）" %>
        <div class="form-text">API 認証が必要な場合に設定（Bearer トークンとして送信）</div>
      </div>

      <div class="mb-3">
        <%= f.label :timeout, "タイムアウト（秒）", class: "form-label" %>
        <%= f.number_field :timeout, class: "form-control", min: 1, max: 3600, placeholder: OcrSetting::DEFAULT_TIMEOUT, style: "max-width: 200px;" %>
        <div class="form-text">API リクエストのタイムアウト時間（デフォルト: <%= OcrSetting::DEFAULT_TIMEOUT %> 秒）</div>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header">
      モデル設定
    </div>
    <div class="card-body">
      <div class="mb-3">
        <%= f.label :model, "モデル名", class: "form-label" %>
        <%= f.text_field :model, class: "form-control", placeholder: "例: llava:latest" %>
        <div class="form-text">OCR に使用する VLM モデル名</div>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header">
      プロンプト設定
    </div>
    <div class="card-body">
      <div class="mb-3">
        <%= f.label :prompt, "プロンプト", class: "form-label" %>
        <%= f.text_area :prompt, class: "form-control", rows: 8, placeholder: OcrSetting::DEFAULT_PROMPT %>
        <div class="form-text">空欄の場合はデフォルトのプロンプトが使用されます</div>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header">
      オプション設定
    </div>
    <div class="card-body">
      <div class="mb-3">
        <%= f.label :options, "options (JSON)", class: "form-label" %>
        <%= f.text_area :options, class: "form-control font-monospace", rows: 6,
            value: @ocr_setting.options.present? ? JSON.pretty_generate(@ocr_setting.options) : JSON.pretty_generate(OcrSetting::DEFAULT_OPTIONS) %>
        <div class="form-text">temperature, num_predict, num_ctx などの設定を JSON 形式で指定</div>
      </div>
    </div>
  </div>

  <div class="d-grid gap-2 d-md-flex justify-content-md-end mb-4">
    <%= f.submit "保存", class: "btn btn-primary" %>
  </div>
<% end %>

<div class="card">
  <div class="card-header">
    現在の設定状態
  </div>
  <div class="card-body">
    <p class="card-text">
      <strong>OCR 機能:</strong>
      <% if OcrApiClient.configured? %>
        <span class="badge bg-success">有効</span>
      <% else %>
        <span class="badge bg-danger">無効</span>
        <br>
        <small class="text-muted">API エンドポイントとモデル名の設定が必要です</small>
      <% end %>
    </p>
  </div>
</div>
