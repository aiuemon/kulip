<%= form_with model: [:admin, @identity_provider] do |f| %>
  <% if @identity_provider.errors.any? %>
    <div class="alert alert-danger">
      <strong><%= @identity_provider.errors.count %>件のエラーがあります:</strong>
      <ul class="mb-0 mt-2">
        <% @identity_provider.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.hidden_field :provider_type %>

  <h6 class="text-muted mb-3">基本設定</h6>

  <div class="mb-3">
    <%= f.label :name, "表示名", class: "form-label" %>
    <%= f.text_field :name, required: true, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :slug, "スラッグ（URL用識別子）", class: "form-label" %>
    <%= f.text_field :slug, placeholder: "自動生成されます", class: "form-control" %>
    <div class="form-text">英小文字、数字、ハイフン、アンダースコアのみ</div>
  </div>

  <div class="form-check mb-2">
    <%= f.check_box :enabled, class: "form-check-input" %>
    <%= f.label :enabled, "有効", class: "form-check-label" %>
  </div>

  <div class="form-check mb-4">
    <%= f.check_box :show_on_login, class: "form-check-input" %>
    <%= f.label :show_on_login, "ログイン画面に表示", class: "form-check-label" %>
  </div>

  <h6 class="text-muted mb-3"><%= @identity_provider.provider_type&.upcase %> 設定</h6>

  <% if @identity_provider.provider_type == "saml" %>
    <div class="mb-3">
      <%= label_tag "settings_idp_sso_url", "IdP SSO URL", class: "form-label" %>
      <%= text_field_tag "identity_provider[settings][idp_sso_url]",
          @identity_provider.settings&.dig("idp_sso_url"),
          id: "settings_idp_sso_url", required: true, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= label_tag "settings_idp_slo_url", "IdP SLO URL（任意）", class: "form-label" %>
      <%= text_field_tag "identity_provider[settings][idp_slo_url]",
          @identity_provider.settings&.dig("idp_slo_url"),
          id: "settings_idp_slo_url", class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= label_tag "settings_idp_cert", "IdP 証明書", class: "form-label" %>
      <%= text_area_tag "identity_provider[settings][idp_cert]",
          @identity_provider.settings&.dig("idp_cert"),
          id: "settings_idp_cert", rows: 10, class: "form-control font-monospace" %>
    </div>

    <div class="mb-3">
      <%= label_tag "settings_sp_entity_id", "SP エンティティ ID", class: "form-label" %>
      <%= text_field_tag "identity_provider[settings][sp_entity_id]",
          @identity_provider.settings&.dig("sp_entity_id") || "kulip",
          id: "settings_sp_entity_id", class: "form-control" %>
    </div>

  <% elsif @identity_provider.provider_type == "oidc" %>
    <div class="mb-3">
      <%= label_tag "settings_issuer", "Issuer URL", class: "form-label" %>
      <%= text_field_tag "identity_provider[settings][issuer]",
          @identity_provider.settings&.dig("issuer"),
          id: "settings_issuer", required: true, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= label_tag "settings_client_id", "Client ID", class: "form-label" %>
      <%= text_field_tag "identity_provider[settings][client_id]",
          @identity_provider.settings&.dig("client_id"),
          id: "settings_client_id", required: true, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= label_tag "settings_client_secret", "Client Secret", class: "form-label" %>
      <%= password_field_tag "identity_provider[settings][client_secret]",
          @identity_provider.settings&.dig("client_secret"),
          id: "settings_client_secret", required: true, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= label_tag "settings_redirect_uri", "Redirect URI", class: "form-label" %>
      <%= text_field_tag "identity_provider[settings][redirect_uri]",
          @identity_provider.settings&.dig("redirect_uri"),
          id: "settings_redirect_uri",
          placeholder: "#{request.base_url}/users/auth/oidc_#{@identity_provider.slug || 'SLUG'}/callback",
          class: "form-control" %>
    </div>
  <% end %>

  <div class="d-grid gap-2 d-md-flex justify-content-md-end">
    <%= f.submit class: "btn btn-primary" %>
  </div>
<% end %>
