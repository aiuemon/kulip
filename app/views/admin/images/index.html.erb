<h1 class="mb-4">画像一覧</h1>

<p class="text-muted"><%== @pagy.info_tag %></p>

<div class="table-responsive">
  <table class="table table-striped table-hover">
    <thead class="table-dark">
      <tr>
        <th><%= sort_link("ID", :id, @sort, @dir) %></th>
        <th><%= sort_link("ファイル名", :name, @sort, @dir) %></th>
        <th>作成ユーザ</th>
        <th><%= sort_link("ステータス", :status, @sort, @dir) %></th>
        <th><%= sort_link("処理時間", :ocr_duration, @sort, @dir) %></th>
        <th><%= sort_link("文字起こし日時", :ocr_completed_at, @sort, @dir) %></th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @images.each do |image| %>
        <tr>
          <td><%= image.id %></td>
          <td><%= image.name %></td>
          <td><%= image.user.name.presence || image.user.email %></td>
          <td>
            <% case image.status %>
            <% when "pending" %>
              <span class="badge bg-secondary">待機中</span>
            <% when "queued" %>
              <span class="badge bg-info">処理待ち</span>
            <% when "processing" %>
              <span class="badge bg-primary">処理中</span>
            <% when "completed" %>
              <span class="badge bg-success">完了</span>
            <% when "failed" %>
              <span class="badge bg-danger">失敗</span>
            <% end %>
          </td>
          <td><%= format_duration(image.ocr_duration) %></td>
          <td><%= image.ocr_completed_at&.strftime("%Y-%m-%d %H:%M:%S") || "-" %></td>
          <td>
            <%= link_to "削除", admin_image_path(image),
                class: "btn btn-sm btn-outline-danger",
                data: {
                  turbo_method: :delete,
                  turbo_confirm: "この画像を削除しますか？"
                } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<nav aria-label="ページナビゲーション">
  <%== @pagy.series_nav %>
</nav>
