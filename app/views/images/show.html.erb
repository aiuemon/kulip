<h1><%= @image.name %></h1>

<dl>
  <dt>ステータス</dt>
  <dd>
    <% case @image.status %>
    <% when "pending" %>
      待機中
    <% when "processing" %>
      処理中
    <% when "completed" %>
      完了
    <% when "failed" %>
      失敗
    <% end %>
  </dd>

  <dt>アップロード日時</dt>
  <dd><%= l(@image.created_at, format: :long) %></dd>
</dl>

<% if @image.file.attached? && @image.file.content_type.start_with?("image/") %>
  <h2>画像</h2>
  <%= image_tag @image.file %>
<% end %>

<% if @image.ocr_result.present? %>
  <h2>OCR 結果</h2>
  <pre><%= @image.ocr_result %></pre>

  <h3>ダウンロード</h3>
  <ul>
    <li><%= link_to "テキスト形式 (.txt)", download_image_path(@image, format: "txt") %></li>
    <li><%= link_to "Markdown 形式 (.md)", download_image_path(@image, format: "md") %></li>
  </ul>
<% end %>

<p>
  <% if @image.image_group %>
    <%= link_to "グループに戻る", image_group_path(@image.image_group) %>
  <% else %>
    <%= link_to "一覧に戻る", image_groups_path %>
  <% end %>
  <% if @image.failed? || @image.pending? %>
    | <%= link_to "再試行", retry_image_path(@image), data: { turbo_method: :post } %>
  <% end %>
  | <%= link_to "削除", image_path(@image), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" } %>
</p>
