#!/bin/bash -e

# If running the rails server then create or migrate existing database
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  ./bin/rails db:prepare
  ./bin/rails db:create:cache db:migrate:cache || true
  ./bin/rails db:create:queue db:migrate:queue || true
  ./bin/rails db:create:cable db:migrate:cable || true
fi

exec "${@}"
